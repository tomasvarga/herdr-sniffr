#!/usr/bin/env bash
# sniffr â€” an AI sniffs a PR for issues before you review it. Opens the PR in
# tuicr IMMEDIATELY, then an agent reviews the diff in the BACKGROUND and injects
# its findings as tuicr local-draft comments (never pushed); the pane reloads
# when they land. You start reading right away â€” comments appear a few sec later.
#
#   sniffr <pr>                  pr = number | owner/repo#N | URL
#   sniffr <pr> --agent grok
#   sniffr queue [--since 3w]    pick from the PRs awaiting your review
#
# Agent (first match wins): --agent flag Â· SNIFFR_AGENT env Â· saved default
# (`sniffr --set-agent <name>`, stored in ~/.config/sniffr/agent) Â· codex.
# SNIFFR_CMD='<cmd>' escape hatch (prompt on stdin -> JSON array on stdout).
# Built-ins: codex Â· claude Â· cursor Â· grok Â· opencode Â· ollama.
set -uo pipefail
die(){ echo "sniffr: $*" >&2; exit 1; }

CONF_DIR="$HOME/.config/sniffr"

# default agent: SNIFFR_AGENT env â†’ saved default file â†’ codex
default_agent(){
  if [ -n "${SNIFFR_AGENT:-}" ]; then printf '%s' "$SNIFFR_AGENT"
  elif [ -s "$CONF_DIR/agent" ]; then tr -d '[:space:]' < "$CONF_DIR/agent"
  else printf 'codex'; fi
}

# notify <title> <body> [sound] â€” prefer the OS notifier (persists in the macOS
# notification centre with full text) over herdr's brief in-app toast.
notify(){
  local title="$1" body="$2" sound="${3:-}"
  if command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier -title "$title" -message "$body" ${sound:+-sound Ping} >/dev/null 2>&1
  elif command -v osascript >/dev/null 2>&1; then
    osascript -e "display notification \"${body//\"/}\" with title \"${title//\"/}\"" >/dev/null 2>&1
  elif command -v herdr >/dev/null 2>&1; then
    herdr notification show "$title" --body "$body" ${sound:+--sound "$sound"} >/dev/null 2>&1
  fi
}

# resolve a PR target into repo / number / tuicr slug
resolve(){
  case "$1" in
    https://github.com/*/pull/*)
      repo=$(printf '%s' "$1" | sed -E 's#https://github.com/([^/]+/[^/]+)/pull/.*#\1#')
      num=$(printf  '%s' "$1" | sed -E 's#.*/pull/([0-9]+).*#\1#') ;;
    */*\#*) repo="${1%#*}"; num="${1#*#}" ;;
    *[0-9]) repo=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) \
              || die "bare number needs a repo cwd; pass owner/repo#N or a URL"
            num="$1" ;;
    *) die "unrecognized PR target: $1" ;;
  esac
  slug="gh:$repo/pr/${num}"
}

# ===================== WORKER: review, inject, reload (bg) =====================
if [ "${1:-}" = "--worker" ]; then
  target="$2"; pid="$3"
  AGENT="$(default_agent)"; MAX="${SNIFFR_MAX:-8}"
  resolve "$target"
  diff=$(gh pr diff "${num}" --repo "$repo" 2>/dev/null) || exit 0
  [ -n "$diff" ] || exit 0
  prompt="You are a senior code reviewer. Review this pull-request unified diff.
Report ONLY high-signal findings: bugs, security issues, correctness risks, and
important design concerns. No nits, no style preferences.
Output ONLY a JSON array â€” no prose, no markdown fences. Each item:
{\"file\":\"<path, new side>\",\"line\":<new-side line number, or null>,\"type\":\"bug|risk|question|note\",\"body\":\"<concise finding>\"}
Use the @@ hunk headers to compute new-side line numbers. At most ${MAX} items.
If nothing significant, output [].

DIFF:
${diff}"
  scratch=$(mktemp -d); trap 'rm -rf "$scratch"' EXIT
  run_agent(){
    if [ -n "${SNIFFR_CMD:-}" ]; then printf '%s' "$prompt" | ( cd "$scratch" && eval "$SNIFFR_CMD" ); return; fi
    ( cd "$scratch"
      case "$AGENT" in
        codex)               printf '%s' "$prompt" | codex exec --skip-git-repo-check - 2>/dev/null ;;
        claude)              printf '%s' "$prompt" | claude -p 2>/dev/null ;;
        cursor|cursor-agent) cursor-agent -p --output-format text "$prompt" 2>/dev/null ;;
        grok)                grok --output-format text "$prompt" 2>/dev/null ;;
        opencode)            opencode run "$prompt" 2>/dev/null ;;
        ollama)              printf '%s' "$prompt" | ollama run "${SNIFFR_MODEL:-llama3.1}" 2>/dev/null ;;
      esac )
  }
  raw=$(run_agent)
  findings=$(printf '%s' "$raw" | python3 -c '
import sys, json
s = sys.stdin.read(); i = s.find("[")
while i != -1:
    for j in range(len(s), i, -1):
        try:
            v = json.loads(s[i:j])
            if isinstance(v, list): print(json.dumps(v)); sys.exit(0)
        except Exception: pass
    i = s.find("[", i + 1)
print("[]")')
  # wait for tuicr to open the PR and persist the session to disk
  found=0
  for _ in $(seq 1 45); do
    if tuicr review list --repo "$repo" 2>/dev/null | jq -e --arg s "$slug" 'any(.[]?; .slug==$s)' >/dev/null 2>&1; then found=1; break; fi
    sleep 0.7
  done
  n=0
  if [ "$found" = 1 ]; then
    while IFS= read -r item; do
      [ -n "$item" ] || continue
      file=$(jq -r '.file // empty'  <<<"$item"); line=$(jq -r '.line // empty' <<<"$item")
      typ=$( jq -r '.type // "note"' <<<"$item"); body=$(jq -r '.body // empty' <<<"$item")
      [ -n "$file" ] && [ -n "$body" ] || continue
      if [ -n "$line" ] && [ "$line" != "null" ]; then
        tuicr review add --session "$slug" --repo "$repo" --type "$typ" --target-file "$file" --line "$line" --side new --username "$AGENT" "$body" >/dev/null 2>&1 && n=$((n+1))
      else
        tuicr review add --session "$slug" --repo "$repo" --type "$typ" --target-file "$file" --username "$AGENT" "$body" >/dev/null 2>&1 && n=$((n+1))
      fi
    done < <(printf '%s' "$findings" | jq -c '.[]?')
    [ -n "$pid" ] && { herdr pane send-text "$pid" ":e" >/dev/null 2>&1; herdr pane send-text "$pid" $'\r' >/dev/null 2>&1; }
  fi
  if   [ "$found" != 1 ]; then notify "sniffr" "$AGENT couldn't attach to the tuicr session for PR #${num} â€” is it still open?"
  elif [ "$n" -gt 0 ];    then notify "sniffr â€” review ready" "$AGENT left $n comment(s) on PR #${num}. Press :e in tuicr if they haven't loaded." done
  else                         notify "sniffr" "$AGENT sniffed PR #${num} and flagged nothing."
  fi
  exit 0
fi

# ============ BG: launch the review worker only (caller opens tuicr) ===========
if [ "${1:-}" = "--bg" ]; then
  target="$2"; pid="${3:-}"
  AGENT="$(default_agent)"
  resolve "$target"
  log="${TMPDIR:-/tmp}/sniffr-${num}.log"
  SNIFFR_AGENT="$AGENT" nohup "$0" --worker "$target" "$pid" >"$log" 2>&1 </dev/null &
  disown 2>/dev/null || true
  notify "sniffr" "${AGENT} is sniffing PR #${num} in the backgroundâ€¦"
  exit 0
fi

# ==================== queue: pick a PR from your review list ===================
# A target picker only â€” the choice is handed back to the normal path via exec,
# so `queue` can never drift from `sniffr <pr>`. Defaults: recent Â· human Â· ready.
if [ "${1:-}" = "queue" ]; then
  shift
  since="21d"; want_bots=0; want_drafts=0; agent_pass=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --since)   since="${2:-}"; shift 2 ;;
      --since=*) since="${1#*=}"; shift ;;
      --agent)   agent_pass="${2:-}"; shift 2 ;;
      --agent=*) agent_pass="${1#*=}"; shift ;;
      --all)     since=""; want_bots=1; want_drafts=1; shift ;;
      --include-bots) want_bots=1; shift ;;
      --drafts)  want_drafts=1; shift ;;
      -*) die "queue: unknown flag: $1" ;;
      *)  die "queue takes no positional args (got '$1')" ;;
    esac
  done
  for b in gh jq; do command -v "$b" >/dev/null || die "missing dependency: $b"; done

  # --since 21d|3w|2mo|1y  â†’  a `gh --updated` server-side date filter
  updated=""
  if [ -n "$since" ]; then
    case "$since" in
      *mo)    adj="-v-${since%mo}m" ;;            # months (macOS date: m=month)
      *[dwy]) adj="-v-${since}" ;;                # days / weeks / years
      *) die "queue: --since wants e.g. 21d, 3w, 2mo, 1y (got '$since')" ;;
    esac
    cutoff=$(date $adj +%Y-%m-%d 2>/dev/null) || die "queue: bad --since '$since'"
    updated=">=$cutoff"
  fi

  # opt-out filters as jq predicates
  botf='select(.author.login | test("dependabot|renovate|-bot$|\\[bot\\]") | not)'
  [ "$want_bots" = 1 ] && botf='.'
  draftf='select(.isDraft | not)'
  [ "$want_drafts" = 1 ] && draftf='.'

  rows=$(gh search prs --review-requested=@me --state=open --limit 200 \
           ${updated:+--updated "$updated"} \
           --json url,title,repository,author,isDraft,updatedAt \
           --jq ".[] | $botf | $draftf
                 | [.updatedAt, .url, (.repository.nameWithOwner + \"  â€”  \" + .title)]
                 | @tsv" 2>/dev/null | sort -r)
  [ -n "$rows" ] || { echo "sniffr queue: nothing needs your review${since:+ (active in last $since)}."; exit 0; }

  urls=(); labels=(); n=0
  while IFS=$'\t' read -r _u url label; do
    [ -n "$url" ] || continue
    urls[$n]="$url"; labels[$n]="$label"; n=$((n+1))
  done <<EOF
$rows
EOF

  sel=0; esc=$(printf '\033')
  draw(){
    printf '%s[1mNeeds your review (%d)%s[0m\r\n' "$esc" "$n" "$esc"
    local i
    for i in $(seq 0 $((n-1))); do
      if [ "$i" = "$sel" ]; then printf '%s[7m â†’ [%d] %s %s[0m\r\n' "$esc" $((i+1)) "${labels[$i]}" "$esc"
      else                       printf '   [%d] %s\r\n' $((i+1)) "${labels[$i]}"; fi
    done
    printf '   [q] cancel\r\n'
  }
  cleanup(){ printf '%s[?25h' "$esc"; }
  trap cleanup EXIT
  printf '%s[?25l' "$esc"; draw
  while IFS= read -rsn1 key; do
    case "$key" in
      "$esc") IFS= read -rsn2 rest
              case "$rest" in "[A") sel=$(((sel-1+n)%n)) ;; "[B") sel=$(((sel+1)%n)) ;; esac ;;
      q|Q) cleanup; echo "queue: cancelled."; exit 0 ;;
      [1-9]) idx=$((key-1)); [ "$idx" -lt "$n" ] && { sel=$idx; break; } ;;
      "") break ;;                                 # Enter
    esac
    printf '%s[%dA' "$esc" $((n+1)); draw
  done
  cleanup
  chosen="${urls[$sel]}"
  [ -n "$chosen" ] || exit 0
  echo "sniffr: â†’ $chosen"
  if [ -n "$agent_pass" ]; then exec "$0" --agent "$agent_pass" "$chosen"
  else                          exec "$0" "$chosen"; fi
fi

# ========================= MAIN: open tuicr + spawn worker ====================
AGENT="$(default_agent)"; target=""
while [ $# -gt 0 ]; do
  case "$1" in
    --agent) AGENT="${2:-}"; shift 2 ;;
    --agent=*) AGENT="${1#*=}"; shift ;;
    --set-agent) a="${2:-}"; [ -n "$a" ] || die "usage: sniffr --set-agent <name>"
      case "$a" in codex|claude|cursor|cursor-agent|grok|opencode|ollama) ;;
        *) echo "sniffr: note â€” '$a' isn't a built-in; set SNIFFR_CMD for a custom tool" >&2 ;; esac
      mkdir -p "$CONF_DIR"; printf '%s\n' "$a" > "$CONF_DIR/agent"
      echo "sniffr: default agent set to '$a' (~/.config/sniffr/agent)"; exit 0 ;;
    --show-agent) echo "sniffr: default agent = $(default_agent)"; exit 0 ;;
    -h|--help) sed -n '2,14p' "$0"; exit 0 ;;
    -*) die "unknown flag: $1" ;;
    *) target="$1"; shift ;;
  esac
done
[ -n "$target" ] || die "usage: sniffr <pr> [--agent NAME]"
for b in gh jq tuicr python3 herdr; do command -v "$b" >/dev/null || die "missing dependency: $b"; done
if [ -z "${SNIFFR_CMD:-}" ]; then
  case "$AGENT" in codex|claude|cursor|cursor-agent|grok|opencode|ollama) : ;;
    *) die "unknown agent '$AGENT'. Built-ins: codex claude cursor grok opencode ollama â€” or set SNIFFR_CMD='<cmd>'." ;; esac
fi
[ -n "${HERDR_SOCKET_PATH:-}" ] || die "not inside herdr â€” run this from a herdr pane"
resolve "$target"

# open tuicr right away in a split so you can start reading immediately
out=$(herdr pane split --current --direction right --focus 2>/dev/null || true)
pid=$(printf '%s' "$out" | jq -r '.result.pane.pane_id // empty')
[ -n "$pid" ] || die "could not open a herdr split"
# NOT exec: an exec'd tuicr launched via `pane run` exits right after load
herdr pane run "$pid" "tuicr pr $target"

# review in a detached background worker; it injects + reloads when ready
log="${TMPDIR:-/tmp}/sniffr-${num}.log"
SNIFFR_AGENT="$AGENT" nohup "$0" --worker "$target" "$pid" >"$log" 2>&1 </dev/null &
disown 2>/dev/null || true
notify "sniffr" "$AGENT is sniffing PR #${num} in the backgroundâ€¦"
echo "sniffr: opened #${num} in tuicr â€” $AGENT sniffing in the background."
