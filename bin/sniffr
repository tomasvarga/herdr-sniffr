#!/usr/bin/env bash
# herdr-sniffr launcher — the herdr integration layer over the standalone
# `sniffr` engine (https://github.com/tomasvarga/sniffr).
#
# Inside herdr, `sniffr <pr>` opens the PR in a reviewer split and runs the
# review in the BACKGROUND, reloading the pane and firing a herdr toast when the
# findings land — the same experience as before the engine was extracted.
# Outside herdr (or for non-review subcommands like doctor/setup/--format json),
# it's a transparent passthrough to the engine.
#
# The engine does all the real work (agents, anchoring, backends, inject); this
# wrapper only adds the two things that are genuinely herdr's job: opening the
# reviewer pane, and wiring the reload + notification hooks.
set -uo pipefail

# --- locate the engine (installed via the `needs = sniffr` plugin dep) --------
self="${BASH_SOURCE[0]:-$0}"
self="$(cd "$(dirname "$self")" && pwd)/$(basename "$self")"
core=""
for c in "${SNIFFR_CORE:-}" \
         "$HOME/.local/share/sniffr/bin/sniffr" \
         "${HERDR_PLUGIN_ROOT:+$HERDR_PLUGIN_ROOT/../sniffr/bin/sniffr}"; do
  [ -n "$c" ] && [ -x "$c" ] && { core="$c"; break; }
done
if [ -z "$core" ]; then                       # any PATH `sniffr` that isn't us
  while IFS= read -r c; do
    [ -n "$c" ] && [ "$c" != "$self" ] && [ -x "$c" ] && { core="$c"; break; }
  done < <(command -v -a sniffr 2>/dev/null)
fi
[ -n "$core" ] || {
  echo "herdr-sniffr: can't find the sniffr engine. Install it:" >&2
  echo "  curl -fsSL https://raw.githubusercontent.com/tomasvarga/sniffr/main/install.sh | bash" >&2
  exit 1
}

# --- herdr-plugin config ------------------------------------------------------
# Read once from the herdr plugins config dir (the dir herdr hands plugin actions
# via HERDR_PLUGIN_CONFIG_DIR, else the standard on-disk path for a plain
# `sniffr <pr>` typed in a pane). Holds herdr-only settings ([pane]) AND optional
# engine overrides so you can drive everything from one file when on herdr.
cfg_json(){
  local f=""
  for c in "${HERDR_PLUGIN_CONFIG_DIR:+$HERDR_PLUGIN_CONFIG_DIR/config.toml}" \
           "${XDG_CONFIG_HOME:-$HOME/.config}/herdr/plugins/config/sniffr/config.toml"; do
    [ -n "$c" ] && [ -f "$c" ] && { f="$c"; break; }
  done
  [ -n "$f" ] || { echo '{}'; return; }
  python3 -c 'import tomllib,json,sys; print(json.dumps(tomllib.load(open(sys.argv[1],"rb"))))' "$f" 2>/dev/null || echo '{}'
}
_cfg="$(cfg_json)"

# Engine overrides: any of these keys in the herdr config is passed to the engine
# as its SNIFFR_* env. Precedence stays sane — CLI flag > shell env > herdr config
# > engine config (~/.config/sniffr) > default — because we only set a var the
# shell hasn't already set, and the engine still lets an explicit flag win.
_set(){ [ -n "${!1:-}" ] && return 0; local v; v="$(printf '%s' "$_cfg" | jq -r "$2 // empty")"; [ -n "$v" ] && [ "$v" != null ] && export "$1=$v"; }
_set SNIFFR_AGENT   '.agent'
_set SNIFFR_MODEL   '.model'
_set SNIFFR_BACKEND '.backend'
_set SNIFFR_MAX     '.max'
_set SNIFFR_PROMPT  '.prompt'
# multi-agent consensus + noise filters (setting [consensus].model turns consensus on)
_set SNIFFR_CONSENSUS_MODEL  '.consensus.model'
_set SNIFFR_CONSENSUS_AGENT  '.consensus.agent'
_set SNIFFR_CONSENSUS_PROMPT '.consensus.prompt'
_set SNIFFR_MIN_SEVERITY     '.min_severity'
_set SNIFFR_MIN_CONFIDENCE   '.min_confidence'

# --- decide whether this invocation should open a reviewer pane ---------------
# Only a plain "review a PR" call inside herdr opens a pane. Subcommands and
# --format json pass straight through to the engine.
open_pane=0
if [ -n "${HERDR_SOCKET_PATH:-}" ] && command -v herdr >/dev/null 2>&1; then
  open_pane=1
  prev=""
  for a in "$@"; do
    case "$a" in
      doctor|queue|setup|open-cmd|--worker|--set-agent|--show-agent|-h|--help) open_pane=0 ;;
      --format=json) open_pane=0 ;;
      json) [ "$prev" = "--format" ] && open_pane=0 ;;
    esac
    prev="$a"
  done
fi

if [ "$open_pane" != 1 ]; then
  # queue picks a PR then re-execs — route that back through THIS wrapper so the
  # picked PR still opens a pane. Harmless for other passthrough subcommands.
  export SNIFFR_REEXEC="$self"
  exec "$core" "$@"
fi

# --- review path: open the reviewer in a split, then review in the background -
# Pane placement ([pane] in the herdr config, read above into $_cfg).
PANE_PLACEMENT="$(printf '%s' "$_cfg" | jq -r '.pane.placement // "split"')"
PANE_DIR="$(printf '%s' "$_cfg" | jq -r '.pane.direction // "right"')"
PANE_RATIO="$(printf '%s' "$_cfg" | jq -r '.pane.ratio // empty')"
case "$PANE_DIR" in right|down) ;; *) PANE_DIR="right" ;; esac

# ask the engine how to launch the resolved backend's viewer (tuicr/hunk/custom)
opencmd="$("$core" open-cmd "$@")" || exit 1
[ -n "$opencmd" ] || echo "herdr-sniffr: no viewer command for this backend — reviewing headless." >&2

out=$(herdr pane split --current --direction "$PANE_DIR" ${PANE_RATIO:+--ratio "$PANE_RATIO"} --focus 2>/dev/null || true)
pid=$(printf '%s' "$out" | jq -r '.result.pane.pane_id // empty')
[ -n "$pid" ] || { echo "herdr-sniffr: could not open a herdr split" >&2; exit 1; }
[ "$PANE_PLACEMENT" = "zoom" ] && herdr pane zoom "$pid" --on >/dev/null 2>&1 || true
[ -n "$opencmd" ] && herdr pane run "$pid" "$opencmd"

# hand off to the engine: background review; reload the pane + toast on landing.
# The engine runs these via `sh -c`, so keep them POSIX (no $'\r' bashism —
# $(printf '\r') yields the carriage return that submits tuicr's :e reload).
exec "$core" "$@" --bg \
  --after-inject "herdr pane send-text $pid ':e' >/dev/null 2>&1; herdr pane send-text $pid \"\$(printf '\r')\" >/dev/null 2>&1" \
  --notify-cmd 'herdr notification show "$SNIFFR_TITLE" "$SNIFFR_MSG" >/dev/null 2>&1'
